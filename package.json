{
  "name": "prism-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Soroban Transaction Debugger — From cryptic error to root cause in one command.",
  "scripts": {
    "dev:web": "pnpm --filter prism-web dev",
    "dev:server": "pnpm --filter prism-server dev",
    "build:web": "pnpm --filter prism-web build",
    "build:server": "pnpm --filter prism-server build",
    "build:vscode": "pnpm --filter prism-vscode build",
    "build:wasm": "powershell -File scripts/build-wasm.ps1",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
